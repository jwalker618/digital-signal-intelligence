# Digital Signal Intelligence - Environment Configuration
# Copy this file to .env and update values for your environment

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Environment: development, staging, production
DSI_ENV=development

# Debug mode (disable in production)
DSI_DEBUG=true

# API version
DSI_API_VERSION=v1

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
DSI_LOG_LEVEL=INFO

# =============================================================================
# SERVER SETTINGS
# =============================================================================

# API host and port
DSI_HOST=0.0.0.0
DSI_PORT=8000

# Number of worker processes (production)
DSI_WORKERS=4

# =============================================================================
# DATABASE SETTINGS
# =============================================================================

# PostgreSQL connection
DATABASE_URL=postgresql+asyncpg://dsi_user:dsi_password@localhost:5432/dsi_db

# Sync URL for migrations
DATABASE_URL_SYNC=postgresql://dsi_user:dsi_password@localhost:5432/dsi_db

# Connection pool settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# =============================================================================
# REDIS / CACHING
# =============================================================================

# Redis connection
REDIS_URL=redis://localhost:6379/0

# Cache TTL defaults (seconds)
CACHE_DEFAULT_TTL=3600
CACHE_SIGNAL_TTL=86400

# =============================================================================
# AUTHENTICATION
# =============================================================================

# JWT settings
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# API key prefix for identification
API_KEY_PREFIX=dsi_

# =============================================================================
# CORS SETTINGS
# =============================================================================

# Allowed origins (comma-separated, use * only in development)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Allow credentials
CORS_ALLOW_CREDENTIALS=true

# =============================================================================
# RATE LIMITING
# =============================================================================

# Requests per minute per client
RATE_LIMIT_PER_MINUTE=60

# Burst limit
RATE_LIMIT_BURST=10

# =============================================================================
# EXTERNAL API KEYS (for real extractors)
# =============================================================================

# SSL Labs API (optional, has free tier)
# SSL_LABS_API_KEY=

# SecurityScorecard API
# SECURITYSCORECARD_API_KEY=

# Shodan API
# SHODAN_API_KEY=

# BuiltWith API
# BUILTWITH_API_KEY=

# Clearbit API
# CLEARBIT_API_KEY=

# OpenCorporates API
# OPENCORPORATES_API_KEY=

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================

# Sentry DSN (error tracking)
# SENTRY_DSN=

# Prometheus metrics endpoint
METRICS_ENABLED=true
METRICS_PATH=/metrics

# Health check settings
HEALTH_CHECK_PATH=/api/v1/health

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable traditional modifiers (Phase 7)
FEATURE_TRADITIONAL_MODIFIERS=true

# Enable/disable multi-coverage orchestration (Phase 10)
FEATURE_MULTI_COVERAGE=true

# Enable/disable website discovery (Phase 6)
FEATURE_DISCOVERY=true

# Use stub extractors (set to false when real extractors are ready)
FEATURE_USE_STUBS=true

# =============================================================================
# V6/D1 — Universal Web Footprint Extractors (kill-switches + API keys)
# =============================================================================
# Kill-switches: set to "true" to shed a specific extractor without a deploy.
DSI_DISABLE_GITHUB_ORG=false
DSI_DISABLE_WAYBACK=false
DSI_DISABLE_URLSCAN=false
DSI_DISABLE_COMMONCRAWL=false
DSI_DISABLE_TRANCO=false
DSI_DISABLE_SAFEBROWSING=false
DSI_DISABLE_PHISHTANK=false
DSI_DISABLE_OPENPHISH=false
DSI_DISABLE_CF_RADAR=false
DSI_DISABLE_GOOGLE_TRANSPARENCY=false
DSI_DISABLE_HIBP=false
DSI_DISABLE_INTELX=false
DSI_DISABLE_TRUSTPILOT=false
DSI_DISABLE_BBB=false
DSI_DISABLE_GLASSDOOR=false
DSI_DISABLE_GOOGLE_REVIEWS=false
# API keys — missing keys cause a neutral-absence result; the framework still runs.
# GITHUB_PAT=
# URLSCAN_API_KEY=
# GOOGLE_SAFEBROWSING_API_KEY=
# CLOUDFLARE_API_TOKEN=
# HIBP_API_KEY=
# INTELX_API_KEY=
# GOOGLE_PLACES_API_KEY=

# =============================================================================
# V6/D3 — Litigation & Regulatory extractor kill-switches
# =============================================================================
DSI_DISABLE_COURTLISTENER=false
DSI_DISABLE_PACER_RSS=false
DSI_DISABLE_SCAC=false
DSI_DISABLE_SEC_LITRELEASES=false
DSI_DISABLE_FINRA=false
DSI_DISABLE_IAPD=false
DSI_DISABLE_GDPR_TRACKER=false
DSI_DISABLE_CMS_HOSPITAL=false
DSI_DISABLE_JOINT_COMMISSION=false
DSI_DISABLE_NPDB=false
DSI_DISABLE_PCAOB=false
DSI_DISABLE_OSHA=false
DSI_DISABLE_FMCSA=false
DSI_DISABLE_NHTSA=false
DSI_DISABLE_CPSC=false
DSI_DISABLE_FDA=false
DSI_DISABLE_EU_SAFETYGATE=false
DSI_DISABLE_FSIS=false
# Optional token
# COURTLISTENER_TOKEN=
