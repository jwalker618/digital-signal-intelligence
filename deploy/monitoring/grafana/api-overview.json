{
  "_comment": "V6 Phase 6 (C3) — DSI API RED-method + SLO-burn overview dashboard. Import via grafana-operator or 'grafana-cli'. Full schema kept minimal on purpose — one source of truth is Prometheus + SLO rules generated by sloth, so this file only wires panels.",
  "schemaVersion": 39,
  "title": "DSI API — Overview",
  "tags": ["dsi", "api", "slo"],
  "timezone": "browser",
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requests/sec",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "sum(rate(http_requests_total{app=\"dsi-api\"}[1m]))"}]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error rate (5m)",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "sum(rate(http_requests_total{app=\"dsi-api\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{app=\"dsi-api\"}[5m])),1)"}]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "p95 /assess latency",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{app=\"dsi-api\",route=\"/api/v1/assess\"}[5m])))"}]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "DB pool used",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "sum(pg_stat_activity_count{app=\"dsi-api\",state=\"active\"})"}]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "SLO burn — availability (1h / 6h)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {"expr": "slo:sli_error:ratio_rate1h{service=\"dsi-api\",slo=\"availability\"}", "legendFormat": "1h"},
        {"expr": "slo:sli_error:ratio_rate6h{service=\"dsi-api\",slo=\"availability\"}", "legendFormat": "6h"}
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Active config versions per pod",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [{"expr": "dsi_config_version_active"}]
    }
  ]
}
