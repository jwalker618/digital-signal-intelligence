# DSI Frontend — environment template.
# Copy to `.env.local` and adjust per environment.

# ─── API ───────────────────────────────────────────────────────────────
# When empty, requests go to the relative path /api/v1/* which is then
# rewritten by next.config.ts to http://localhost:8000 in dev. Set this
# to a fully-qualified URL in production / staging.
NEXT_PUBLIC_API_URL=

# ─── PWA / Push ────────────────────────────────────────────────────────
# VAPID public key for Web Push. Generated server-side and exposed to
# the client so subscriptions can be created.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
