# SHODAN_API_KEY=
# CENSYS_API_ID=
# CENSYS_API_SECRET=
# BUILTWITH_API_KEY=

# =============================================================================
# V6/D5 — Climate / Environment extractor kill-switches
# =============================================================================
DSI_DISABLE_FEMA_FLOOD=false
DSI_DISABLE_NOAA_CDO=false
DSI_DISABLE_USFS_FIRE=false
DSI_DISABLE_USGS_SEISMIC=false
DSI_DISABLE_COPERNICUS=false
DSI_DISABLE_ERA5=false
DSI_DISABLE_CDP=false
DSI_DISABLE_ENERGYSTAR=false
DSI_DISABLE_TRI=false
DSI_DISABLE_SUPERFUND=false
DSI_DISABLE_NRC=false
