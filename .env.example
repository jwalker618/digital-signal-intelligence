DSI_DISABLE_GREENHOUSE=false
DSI_DISABLE_LEVER=false
DSI_DISABLE_ASHBY=false
DSI_DISABLE_GOOGLE_JOBS=false
# Optional (SerpAPI for Google Jobs)
# SERPAPI_API_KEY=

# =============================================================================
# V8 — Client portal demo (python -m seed demo-reset)
# =============================================================================
# Shared password set on all demo users (Marsh broker + 3 client tenants +
# fallback underwriter). Override before the demo if needed.
DSI_DEMO_PASSWORD=demo-pass-2026
# Seed for the cohort pool RNG -- keep fixed for deterministic state.
DSI_DEMO_RNG_SEED=42
