DSI_DISABLE_USPTO=false
DSI_DISABLE_EPO=false
DSI_DISABLE_OPENALEX=false
DSI_DISABLE_CROSSREF=false
DSI_DISABLE_SEMANTIC_SCHOLAR=false
# Optional
# EPO_OPS_KEY=
# SEMANTIC_SCHOLAR_API_KEY=

# =============================================================================
# V6/D6 — Sector telemetry kill-switches
# =============================================================================
DSI_DISABLE_OPENSKY=false
DSI_DISABLE_ICAO=false
DSI_DISABLE_ASIAS=false
DSI_DISABLE_AIS_HUB=false
DSI_DISABLE_MARINE_CADASTRE=false
DSI_DISABLE_EMSA=false
DSI_DISABLE_PARIS_MOU=false
DSI_DISABLE_TOKYO_MOU=false
DSI_DISABLE_PHMSA=false
DSI_DISABLE_BSEE=false
DSI_DISABLE_NERC=false
